#include<stdio.h>
#include<stdlib.h>

struct Queue{
    int size;
    int f;
    int r;
    int *arr;
};

int isFull(struct Queue*q){
    if(q->r == q->size-1){
        return 1;
    }
    else{
        return 0;
    }
}

int isEmpty(struct Queue*q){
    if(q->r == q->f){
        return 1;
    }
    else{
        return 0;
    }
}


void Enque(struct Queue *q,int value){
    if(isFull(q)){
        printf("Queue is full\n");
    }
    else{
        q->r++;
        q->arr[q->r] = value;
        printf("Inserted Element is:-%d\n",value);
    }
}
int Deque(struct Queue*q){
    int a=-1;
    if(isEmpty(q)){
        printf("Queue is Empty \n");
    }
    else{
        q->f = q->f+1;
        a = q->arr[q->f];

        if(q->f == q->r){
            q->f = -1;
            q->r = -1;
        }
    }
    return a;
}
int main(){

    struct Queue q;
    q.size = 2;
    q.f = -1;
    q.r = -1;
    q.arr = (int*)malloc(q.size*sizeof(int));

    // Enque few Element
    Enque(&q ,20);
    Enque(&q ,50);

    printf("Deque Element is :-%d\n",Deque(&q));
    printf("Deque Element is :-%d\n",Deque(&q));

    Enque(&q ,20);
    Enque(&q ,50);
    Enque(&q ,20);
    Enque(&q ,50);

    if(isFull(&q)){
        printf("Queue is full\n");
    }
    if(isEmpty(&q)){
        printf("Queue is Empty\n");
    }

    return 0;

}

